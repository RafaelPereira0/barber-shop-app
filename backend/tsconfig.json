{
  "compilerOptions": {
    "module": "commonjs",
    "target": "esnext",
    "types": ["node", "express"], 
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "sourceMap": true,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}